{
  "expo": {
    "name": "GameOn",
    "slug": "gameon",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gameon",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0A0E14",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gameon.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCalendarsUsageDescription": "GameOn иска достъп до календара за да добави мачове",
        "NSLocationWhenInUseUsageDescription": "GameOn иска локацията ти за да покаже мачове наоколо",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.gameon.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E14"
      },
      "permissions": [
        "CALENDAR",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6",
          "androidMode": "default",
          "androidCollapsedTitle": "GameOn"
        }
      ],
      "expo-calendar",
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/REPLACE_WITH_EAS_PROJECT_ID"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "experiments": {
      "typedRoutes": false
    }
  }
}
